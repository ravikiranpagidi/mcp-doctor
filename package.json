{
  "name": "mcp-doctor",
  "version": "0.1.0",
  "description": "A friendly production-readiness scanner for Model Context Protocol servers.",
  "type": "module",
  "bin": {
    "mcp-doctor": "./bin/mcp-doctor.js"
  },
  "scripts": {
    "start": "node ./bin/mcp-doctor.js scan .",
    "test": "node --test",
    "scan:example": "node ./bin/mcp-doctor.js scan ./examples/demo-mcp-server",
    "list-rules": "node ./bin/mcp-doctor.js --list-rules"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "security",
    "observability",
    "developer-tools",
    "static-analysis",
    "production-readiness",
    "cli"
  ],
  "author": "Ravi Kiran Pagidi",
  "license": "MIT",
  "homepage": "https://github.com/ravikiranpagidi/mcp-doctor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ravikiranpagidi/mcp-doctor.git"
  },
  "bugs": {
    "url": "https://github.com/ravikiranpagidi/mcp-doctor/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "README.md",
    "LICENSE"
  ]
}
